<%
  // 统一合并：站点 config + 主题 config
  const themeCfg = theme;
  const siteCfg  = config;

  // ---- 标题 ----
  let seoTitle = siteCfg.title;
  if (is_post() || is_page()) {
    seoTitle = (page.title ? page.title + ' · ' : '') + siteCfg.title;
  } else if (is_archive()) {
    const label = '归档';
    seoTitle = label + ' · ' + siteCfg.title;
  } else if (is_category()) {
    seoTitle = '分类：' + page.category + ' · ' + siteCfg.title;
  } else if (is_tag()) {
    seoTitle = '标签：' + page.tag + ' · ' + siteCfg.title;
  }

  // ---- 描述 ----
  const desc = (page.description || page.excerpt || siteCfg.description || '').toString().replace(/<[^>]+>/g, '').trim();

  // ---- URL / Canonical ----
  let canonicalPath = page.path || '/';
  // 首页、归档 index 这类使用 "index.html" 结尾的 path 清理掉
  canonicalPath = canonicalPath.replace(/index\.html$/, '');
  if (canonicalPath.charAt(0) !== '/') canonicalPath = '/' + canonicalPath;
  const absUrl = (siteCfg.url || '').replace(/\/$/, '') + canonicalPath;

  // ---- OG Image ----
  const ogImg = page.og_img || page.index_img || themeCfg.og_image || '/img/og-cover.svg';
  const ogImgAbs = /^https?:/i.test(ogImg) ? ogImg : (siteCfg.url || '').replace(/\/$/, '') + ogImg;

  // ---- Accent 颜色 ----
  const accentLight = themeCfg.accent_light || '#343f60';
  const accentDark  = themeCfg.accent_dark  || '#a0c4ff';
%>
<!DOCTYPE html>
<html lang="<%= siteCfg.language || 'zh-CN' %>" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="color-scheme" content="light dark">
  <meta name="theme-color" content="<%= accentLight %>" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="<%= accentDark %>" media="(prefers-color-scheme: dark)">

  <title><%= seoTitle %></title>
  <meta name="description" content="<%= desc %>">
  <% if (siteCfg.keywords) { %><meta name="keywords" content="<%= siteCfg.keywords %>"><% } %>
  <meta name="author" content="<%= (themeCfg.author && themeCfg.author.name) || siteCfg.author || 'Author' %>">
  <meta name="generator" content="Hexo">

  <% if (themeCfg.canonical) { %><link rel="canonical" href="<%= absUrl %>"><% } %>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/img/apple-touch-icon.svg">

  <!-- Open Graph -->
  <meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
  <meta property="og:site_name" content="<%= siteCfg.title %>">
  <meta property="og:locale" content="zh_CN">
  <meta property="og:title" content="<%= page.title || siteCfg.title %>">
  <meta property="og:description" content="<%= desc %>">
  <meta property="og:url" content="<%= absUrl %>">
  <meta property="og:image" content="<%= ogImgAbs %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= page.title || siteCfg.title %>">
  <meta name="twitter:description" content="<%= desc %>">
  <meta name="twitter:image" content="<%= ogImgAbs %>">

  <!-- Feed -->
  <% if (siteCfg.feed && siteCfg.feed.path) { %>
    <link rel="alternate" type="application/atom+xml" title="<%= siteCfg.title %>" href="/<%= siteCfg.feed.path %>">
  <% } %>

  <!-- 主题 CSS（关键路径，preload 加速） -->
  <link rel="preload" href="<%- url_for('/css/paper.css') %>" as="style">
  <link rel="stylesheet" href="<%- url_for('/css/paper.css') %>">

  <!-- 组件 CSS：仅在音乐/健身页加载 -->
  <%
    const needWidgets = /^\/?(?:music|fitness)\//.test(page.path || '');
  %>
  <% if (needWidgets) { %>
    <link rel="stylesheet" href="<%- url_for('/css/paper-widgets.css') %>">
  <% } %>

  <!-- 额外 CSS（主题 config） -->
  <% (themeCfg.custom_css || []).forEach(function(href) { %>
    <link rel="stylesheet" href="<%- url_for(href) %>">
  <% }); %>

  <!-- 防 FOUC：在任何内容渲染前解析主题偏好 -->
  <script>
    (function () {
      try {
        var stored = localStorage.getItem('paper-theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {}
    })();
  </script>

  <%- themeCfg.custom_head %>
</head>
