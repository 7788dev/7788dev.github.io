<% if (page.total > 1) { %>
<nav class="paginator" aria-label="分页">
  <% if (page.prev) { %>
    <a class="pg-btn" rel="prev" href="<%- url_for(page.prev_link) %>">← 上一页</a>
  <% } else { %>
    <span class="pg-btn is-disabled">← 上一页</span>
  <% } %>

  <span class="pg-info"><%= page.current %> / <%= page.total %></span>

  <% if (page.next) { %>
    <a class="pg-btn" rel="next" href="<%- url_for(page.next_link) %>">下一页 →</a>
  <% } else { %>
    <span class="pg-btn is-disabled">下一页 →</span>
  <% } %>
</nav>
<% } %>
