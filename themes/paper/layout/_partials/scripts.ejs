<%
  const footer = theme.footer || {};
  const idleScripts = [];
  if (footer.statistics) {
    idleScripts.push('https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js');
  }
  (theme.custom_js || []).forEach(function(src) {
    idleScripts.push(url_for(src));
  });
%>
<script src="<%- url_for('/js/paper.js') %>" defer></script>

<% if (idleScripts.length) { %>
  <script>
    (function () {
      var scripts = <%- JSON.stringify(idleScripts) %>;
      function loadIdleScripts() {
        scripts.forEach(function (src) {
          var s = document.createElement('script');
          s.src = src;
          s.defer = true;
          document.body.appendChild(s);
        });
      }
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(loadIdleScripts, { timeout: 2500 });
      } else {
        window.addEventListener('load', function () {
          window.setTimeout(loadIdleScripts, 1);
        }, { once: true });
      }
    })();
  </script>
<% } %>
