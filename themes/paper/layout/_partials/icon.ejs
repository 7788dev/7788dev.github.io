<% } else if (name === 'link') { %>
  <svg viewBox="0 0 24 24" width="<%= size %>" height="<%= size %>" aria-hidden="true">
    <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 14a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 10a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/>
  </svg>
<% } else { %>
  <svg viewBox="0 0 24 24" width="<%= size %>" height="<%= size %>" aria-hidden="true">
    <circle cx="12" cy="12" r="4" fill="currentColor"/>
  </svg>
<% } %>
